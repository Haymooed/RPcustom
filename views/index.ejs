<div id="saveBar"><span class="save-msg">Unsaved changes</span><button class="btn btn-ghost" onclick="loadConfig()">Discard</button><button class="btn btn-primary" onclick="saveConfig()">Save</button></div>
<div id="toasts"></div>

<script>
let cfg={}, settings={}, autoFeaturesCfg={}, isDirty=false, questPollTimer=null;
let allDMs=[], allServers=[], activeDMChannel=null;

// ── Helpers ─────────────────────────────────────────────────────────────────
function toast(msg,type='info'){const el=document.createElement('div');el.className=`toast ${type}`;el.textContent=msg;document.getElementById('toasts').appendChild(el);setTimeout(()=>el.remove(),3200)}
function e(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function gv(id){return document.getElementById(id)?.value||''}
function sv(id,v){const el=document.getElementById(id);if(el)el.value=v}
function on(id){return document.getElementById(id)?.classList.contains('on')||false}
function st(id,val){const el=document.getElementById(id);if(el)el.classList.toggle('on',!!val)}
function initials(name){return (name||'?').slice(0,2).toUpperCase()}
function fmtUptime(ms){if(!ms)return'—';const s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60),d=Math.floor(h/24);return d?`${d}d ${h%24}h`:h?`${h}h ${m%60}m`:`${m}m`}

function showSection(el){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  const sec=el.dataset.sec;
  document.getElementById('sec-'+sec).classList.add('active');
  document.getElementById('topbarTitle').textContent=el.querySelector('span')?.textContent||sec;
  if(sec==='quests'){fetchQuests();loadQuestHistory()}
  if(sec==='messages')loadMessages()
  if(sec==='automation')loadAutoFeatures()
  if(sec==='dms')loadDMs()
  if(sec==='servers')loadServers()
  if(sec==='accounts')loadAccounts()
  if(sec==='settings'){loadQuestHistory();loadAccountsForSettings()}
  if(sec==='dashboard')loadDashboard()
}

function showSectionById(id){
  const el=document.querySelector(`[data-sec="${id}"]`);
  if(el)showSection(el)
}

// ── Init ────────────────────────────────────────────────────────────────────
async function init(){
  await Promise.all([loadConfig(),loadSettingsData(),pollStatus()]);
  loadDashboard();
  setInterval(pollStatus,5000);
  setInterval(loadDashboard,15000);
}

// ── Config ──────────────────────────────────────────────────────────────────
async function loadConfig(){
  try{const r=await fetch('/api/config');const d=await r.json();cfg=d.config||{};applyConfigToForm(cfg);isDirty=false;document.getElementById('saveBar').classList.remove('visible')}
  catch{toast('Failed to load config','err')}
}

function applyConfigToForm(c){
  sv('tokenInput',c.token==='PASTE_YOUR_TOKEN_HERE'?'':(c.token||''));
  sv('statusSelect',c.status||'online');
  st('rpcToggle',c.rpc?.enabled!==false);
  sv('actType',c.rpc?.type||'PLAYING');sv('rpcName',c.rpc?.name||'');sv('appId',c.rpc?.application_id||'');
  sv('rpcDetails',c.rpc?.details||'');sv('rpcState',c.rpc?.state||'');sv('streamUrl',c.rpc?.stream_url||'');
  sv('largeImg',c.rpc?.large_image||'');sv('largeText',c.rpc?.large_text||'');
  sv('smallImg',c.rpc?.small_image||'');sv('smallText',c.rpc?.small_text||'');
  sv('btn1text',c.rpc?.button1_text||'');sv('btn1url',c.rpc?.button1_url||'');
  sv('btn2text',c.rpc?.button2_text||'');sv('btn2url',c.rpc?.button2_url||'');
  st('elapsedToggle',!!c.rpc?.show_elapsed);
  st('csToggle',!!c.custom_status?.enabled);sv('csText',c.custom_status?.text||'');sv('csEmoji',c.custom_status?.emoji||'');
  document.getElementById('streamUrlField').style.display=(c.rpc?.type==='STREAMING')?'':'none';
  updatePreview()
}

async function saveConfig(){
  const payload={token:gv('tokenInput')||cfg.token,status:gv('statusSelect'),rpc:{enabled:on('rpcToggle'),type:gv('actType'),name:gv('rpcName'),application_id:gv('appId'),details:gv('rpcDetails'),state:gv('rpcState'),stream_url:gv('streamUrl'),large_image:gv('largeImg'),large_text:gv('largeText'),small_image:gv('smallImg'),small_text:gv('smallText'),button1_text:gv('btn1text'),button1_url:gv('btn1url'),button2_text:gv('btn2text'),button2_url:gv('btn2url'),show_elapsed:on('elapsedToggle')},custom_status:{enabled:on('csToggle'),text:gv('csText'),emoji:gv('csEmoji')}};
  try{const r=await fetch('/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const d=await r.json();if(d.success){cfg={...cfg,...payload};isDirty=false;document.getElementById('saveBar').classList.remove('visible');toast('Saved!','ok')}else toast(d.error||'Failed','err')}
  catch{toast('Save failed','err')}
}

// ── Settings ─────────────────────────────────────────────────────────────────
async function loadSettingsData(){
  try{const r=await fetch('/api/settings');const d=await r.json();settings=d.settings||{};applySettings(settings)}catch{}
}

function applySettings(s){
  sv('webhookUrl',s.webhookUrl||'');
  st('autoClaimToggle',!!s.autoClaimQuests);st('questNotifToggle',!!s.questNotifications);
  st('rotToggle',!!s.presenceRotation?.enabled);sv('rotInterval',s.presenceRotation?.intervalMinutes||5);
  renderRotList(s.presenceRotation?.presences||[]);
  st('idleToggle',!!s.idleSpoof?.enabled);sv('idleTimeout',s.idleSpoof?.timeoutMinutes||10);
  st('kwToggle',!!s.keywordAlerts?.enabled);renderKwList(s.keywordAlerts?.keywords||[]);
}

async function saveSettings(){
  const updated={...settings,webhookUrl:gv('webhookUrl'),autoClaimQuests:on('autoClaimToggle'),questNotifications:on('questNotifToggle'),presenceRotation:{enabled:on('rotToggle'),intervalMinutes:parseInt(gv('rotInterval'))||5,presences:settings.presenceRotation?.presences||[]},idleSpoof:{enabled:on('idleToggle'),timeoutMinutes:parseInt(gv('idleTimeout'))||10},keywordAlerts:{enabled:on('kwToggle'),keywords:settings.keywordAlerts?.keywords||[]}};
  try{const r=await fetch('/api/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(updated)});const d=await r.json();if(d.success){settings=d.settings;toast('Saved','ok')}else toast(d.error||'Failed','err')}catch{toast('Failed','err')}
}

// ── Dashboard ─────────────────────────────────────────────────────────────────
async function loadDashboard(){
  try{
    const r=await fetch('/api/dashboard');const d=await r.json();
    document.getElementById('dUptime').textContent=fmtUptime(d.uptimeMs);
    document.getElementById('dPing').textContent=d.ping!=null?d.ping+'ms':'—';
    document.getElementById('dToday').textContent=d.questsToday||0;
    document.getElementById('dTotal').textContent=d.questsTotal||0;
    // Account card
    const av=document.getElementById('dashAvatar');
    if(d.avatar){av.innerHTML=`<img src="${e(d.avatar)}" onerror="this.parentElement.textContent='${initials(d.tag)}'">`}
    else{av.textContent=initials(d.tag)}
    document.getElementById('dashTag').textContent=d.tag||'Not connected';
    document.getElementById('dashId').textContent=d.userId?'ID: '+d.userId:'';
    const sb=document.getElementById('dashStateBadge');
    sb.innerHTML=d.state==='connected'?'<span class="badge badge-green">● Connected</span>':d.state==='connecting'?'<span class="badge badge-yellow">● Connecting</span>':'<span class="badge badge-gray">● Disconnected</span>';
    // System status
    document.getElementById('sysDiscord').className='badge '+(d.state==='connected'?'badge-green':'badge-gray');
    document.getElementById('sysDiscord').textContent=d.state==='connected'?'Online':'Offline';
    document.getElementById('sysRotation').className='badge '+(settings.presenceRotation?.enabled?'badge-cyan':'badge-gray');
    document.getElementById('sysRotation').textContent=settings.presenceRotation?.enabled?'On':'Off';
    document.getElementById('sysIdle').className='badge '+(settings.idleSpoof?.enabled?'badge-cyan':'badge-gray');
    document.getElementById('sysIdle').textContent=settings.idleSpoof?.enabled?'On':'Off';
    document.getElementById('sysAutoClaim').className='badge '+(settings.autoClaimQuests?'badge-cyan':'badge-gray');
    document.getElementById('sysAutoClaim').textContent=settings.autoClaimQuests?'On':'Off';
    // Recent history
    const rh=document.getElementById('dashRecentHistory');
    if(d.recentHistory?.length){
      rh.innerHTML='<div style="display:flex;flex-direction:column;gap:5px">'+d.recentHistory.map(h=>{
        const dt=new Date(h.completedAt);
        return`<div class="item-row"><span class="it">${e(h.name)}</span><span class="im">${dt.toLocaleDateString()}</span>${h.success?'<span class="badge badge-green">Done</span>':'<span class="badge badge-red">Failed</span>'}</div>`;
      }).join('')+'</div>';
    }else{rh.innerHTML='<div style="color:var(--text-2);font-size:13px;text-align:center;padding:16px 0">No activity yet</div>'}
  }catch{}
}

// ── Status poll ──────────────────────────────────────────────────────────────
async function pollStatus(){
  try{
    const r=await fetch('/api/status');const d=await r.json();
    document.getElementById('footDot').className='dot '+(d.state||'');
    document.getElementById('footTag').textContent=d.tag||d.state||'Not connected';
    document.getElementById('connectBtn').style.display=d.state==='connected'?'none':'';
    document.getElementById('disconnectBtn').style.display=d.state==='connected'?'':'none';
    if(document.getElementById('setStatus'))document.getElementById('setStatus').textContent=d.state==='connected'?'Online':(d.state||'—');
  }catch{}
}

async function toggleConnect(){
  const cls=document.getElementById('footDot').className;
  if(cls.includes('connected')){await fetch('/api/stop',{method:'POST'});toast('Disconnected','info')}
  else{if(isDirty)await saveConfig();const r=await fetch('/api/start',{method:'POST'});const d=await r.json();if(!d.success)toast(d.error||'Failed','err')}
  setTimeout(pollStatus,600)
}

// ── Presence ──────────────────────────────────────────────────────────────────
function updatePreview(){
  const t=gv('actType');
  document.getElementById('streamUrlField').style.display=t==='STREAMING'?'':'none';
  document.getElementById('prevType').textContent=t;
  document.getElementById('prevName').textContent=gv('rpcName')||'Onyx';
  const det=gv('rpcDetails'),sta=gv('rpcState');
  const pd=document.getElementById('prevDetails'),ps=document.getElementById('prevState');
  pd.textContent=det;pd.style.display=det?'':'none';ps.textContent=sta;ps.style.display=sta?'':'none';
}

function markDirty(){if(!isDirty){isDirty=true;document.getElementById('saveBar').classList.add('visible')}}

async function validateToken(){
  const box=document.getElementById('tokenValidResult');box.innerHTML='<div style="color:var(--text-2)">Validating…</div>';
  try{const r=await fetch('/api/validate-token');const d=await r.json();
    if(d.success){box.innerHTML=`<div style="text-align:center"><div style="font-size:18px;font-weight:700;background:var(--grad-text);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">${e(d.user.username)}</div><div style="font-size:11px;color:var(--text-2);margin-top:3px">ID: ${d.user.id}</div><div style="margin-top:7px"><span class="badge badge-green">✓ Valid</span></div></div>`}
    else{box.innerHTML=`<div style="text-align:center"><span class="badge badge-red">✗ ${e(d.error)}</span></div>`}
  }catch{box.innerHTML='<div style="color:var(--red);font-size:13px">Validation failed</div>'}
}

// Rotation / idle helpers
function addRotEntry(){const name=gv('rotName').trim();if(!name){toast('Enter a name','err');return}if(!settings.presenceRotation)settings.presenceRotation={enabled:false,intervalMinutes:5,presences:[]};settings.presenceRotation.presences.push({type:gv('rotType'),name,application_id:gv('rotAppId')||undefined});renderRotList(settings.presenceRotation.presences);sv('rotName','');sv('rotAppId','')}
function removeRotEntry(i){settings.presenceRotation.presences.splice(i,1);renderRotList(settings.presenceRotation.presences)}
function renderRotList(list){document.getElementById('rotList').innerHTML=list.map((p,i)=>`<div class="item-row"><span class="im">${e(p.type)}</span><span class="it">${e(p.name)}</span><button class="icon-btn del" onclick="removeRotEntry(${i})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:8px">No entries</div>'}
function addKeyword(){const kw=gv('kwInput').trim();if(!kw)return;if(!settings.keywordAlerts)settings.keywordAlerts={enabled:false,keywords:[]};settings.keywordAlerts.keywords.push(kw);renderKwList(settings.keywordAlerts.keywords);sv('kwInput','')}
function removeKeyword(i){settings.keywordAlerts.keywords.splice(i,1);renderKwList(settings.keywordAlerts.keywords)}
function renderKwList(list){document.getElementById('kwList').innerHTML=list.map((k,i)=>`<div class="item-row"><span class="it">${e(k)}</span><button class="icon-btn del" onclick="removeKeyword(${i})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:8px">No keywords</div>'}

// ── DM Inbox ──────────────────────────────────────────────────────────────────
async function loadDMs(){
  const list=document.getElementById('dmList');
  list.innerHTML='<div style="color:var(--text-2);font-size:12px;text-align:center;padding:14px">Loading…</div>';
  try{
    const r=await fetch('/api/dms');const d=await r.json();
    if(!d.success){list.innerHTML=`<div style="color:var(--red);font-size:12px;padding:10px">${e(d.error)}</div>`;return}
    allDMs=d.channels||[];renderDMList(allDMs);
  }catch(err){list.innerHTML=`<div style="color:var(--red);font-size:12px;padding:10px">${e(err.message)}</div>`}
}

function filterDMs(){const q=gv('dmSearch').toLowerCase();renderDMList(allDMs.filter(c=>c.recipientName.toLowerCase().includes(q)))}

function renderDMList(channels){
  const list=document.getElementById('dmList');
  if(!channels.length){list.innerHTML='<div style="color:var(--text-2);font-size:12px;text-align:center;padding:14px">No DMs found</div>';return}
  list.innerHTML=channels.map(c=>{
    const preview=c.lastMessage?.content||'';
    const time=c.lastMessage?.timestamp?new Date(c.lastMessage.timestamp).toLocaleDateString():'';
    const av=c.recipientAvatar?`<img src="${e(c.recipientAvatar)}" onerror="this.style.display='none'">`:'';
    return`<div class="dm-item${activeDMChannel===c.id?' active':''}" onclick="openDM('${c.id}','${e(c.recipientName)}')">
      <div class="dm-avatar">${av||initials(c.recipientName)}</div>
      <div class="dm-info"><div class="dm-name">${e(c.recipientName)}</div><div class="dm-preview">${e(preview.slice(0,50))}</div></div>
      <div style="font-size:10px;color:var(--text-3);flex-shrink:0">${time}</div>
    </div>`;
  }).join('');
}

async function openDM(channelId, recipientName){
  activeDMChannel=channelId;
  document.getElementById('dmChatHeader').textContent=recipientName;
  document.getElementById('dmInputBar').style.display='flex';
  const msgs=document.getElementById('dmMessages');
  msgs.innerHTML='<div class="dm-empty">Loading…</div>';
  renderDMList(allDMs);
  try{
    const r=await fetch(`/api/dms/${channelId}/messages`);const d=await r.json();
    if(!d.success){msgs.innerHTML=`<div class="dm-empty" style="color:var(--red)">${e(d.error)}</div>`;return}
    if(!d.messages?.length){msgs.innerHTML='<div class="dm-empty">No messages</div>';return}
    msgs.innerHTML=d.messages.map(m=>{
      const cls=m.isSelf?'self':'other';
      const av=m.authorAvatar?`<img src="${e(m.authorAvatar)}" onerror="this.style.display='none'">`:'';
      const time=new Date(m.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
      return`<div class="msg-row ${cls}">
        <div class="msg-avatar">${av||initials(m.authorName)}</div>
        <div><div class="msg-bubble">${e(m.content)}</div><div class="msg-time">${time}</div></div>
      </div>`;
    }).join('');
    msgs.scrollTop=msgs.scrollHeight;
  }catch(err){msgs.innerHTML=`<div class="dm-empty" style="color:var(--red)">${e(err.message)}</div>`}
}

async function sendDMReply(){
  const msg=gv('dmReplyInput').trim();if(!msg||!activeDMChannel)return;
  sv('dmReplyInput','');
  const r=await fetch(`/api/dms/${activeDMChannel}/send`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg})});
  const d=await r.json();
  if(d.success){setTimeout(()=>openDM(activeDMChannel,document.getElementById('dmChatHeader').textContent),500)}
  else toast(d.error||'Failed','err')
}

// ── Server Browser ────────────────────────────────────────────────────────────
async function loadServers(){
  const grid=document.getElementById('serverGrid');
  grid.innerHTML='<div style="color:var(--text-2);font-size:13px;text-align:center;padding:22px 0;grid-column:1/-1">Loading…</div>';
  try{
    const r=await fetch('/api/servers');const d=await r.json();
    if(!d.success){grid.innerHTML=`<div style="color:var(--red);font-size:13px;grid-column:1/-1;text-align:center;padding:22px 0">${e(d.error)}</div>`;return}
    allServers=d.guilds||[];
    document.getElementById('serverCount').textContent=`${d.total} servers`;
    renderServerGrid(allServers);
  }catch(err){grid.innerHTML=`<div style="color:var(--red);font-size:13px;grid-column:1/-1;text-align:center;padding:22px 0">${e(err.message)}</div>`}
}

function filterServers(){const q=gv('serverSearch').toLowerCase();renderServerGrid(allServers.filter(g=>g.name.toLowerCase().includes(q)))}

function renderServerGrid(guilds){
  const grid=document.getElementById('serverGrid');
  if(!guilds.length){grid.innerHTML='<div style="color:var(--text-2);font-size:13px;text-align:center;padding:22px 0;grid-column:1/-1">No servers found</div>';return}
  grid.innerHTML=guilds.map(g=>{
    const ic=g.icon?`<img src="${e(g.icon)}" onerror="this.style.display='none'">`:'';
    const own=g.isOwner?'<span class="badge badge-purple" style="margin-top:4px">Owner</span>':'';
    return`<div class="server-card">
      <div class="server-icon">${ic||initials(g.name)}</div>
      <div class="server-name">${e(g.name)}</div>
      <div class="server-meta">${(g.memberCount||0).toLocaleString()} members</div>
      ${own}
    </div>`;
  }).join('');
}

// ── Accounts ──────────────────────────────────────────────────────────────────
async function loadAccounts(){
  try{
    const r=await fetch('/api/accounts');const d=await r.json();
    renderAccountList(d.accounts||[]);
  }catch{}
}

async function loadAccountsForSettings(){
  try{const r=await fetch('/api/accounts');const d=await r.json();const el=document.getElementById('setAccounts');if(el)el.textContent=d.accounts?.length||0}catch{}
}

function renderAccountList(accounts){
  const el=document.getElementById('accountList');
  if(!accounts.length){el.innerHTML='<div style="color:var(--text-2);font-size:13px;text-align:center;padding:22px 0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg)">No accounts saved yet</div>';return}
  el.innerHTML=accounts.map(a=>`
    <div class="account-card${a.active?' active-acc':''}">
      <div class="acc-avatar">${initials(a.nickname)}</div>
      <div class="acc-info">
        <div class="acc-name">${e(a.nickname)}${a.active?' <span class="badge badge-cyan" style="font-size:9px">Active</span>':''}</div>
        <div class="acc-token">${e(a.tokenPreview)}</div>
      </div>
      <div style="display:flex;gap:6px">
        ${!a.active?`<button class="btn btn-ghost" style="padding:5px 10px;font-size:12px" onclick="switchAccount('${a.id}')">Switch</button>`:''}
        <button class="icon-btn del" onclick="removeAccount('${a.id}')"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>`).join('');
}

async function addAccount(){
  const nickname=gv('accNickname').trim(),token=gv('accToken').trim();
  if(!nickname||!token){toast('Fill both fields','err');return}
  const r=await fetch('/api/accounts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({nickname,token})});
  const d=await r.json();
  if(d.success){toast('Account saved','ok');sv('accNickname','');sv('accToken','');loadAccounts()}
  else toast(d.error||'Failed','err')
}

async function switchAccount(id){
  toast('Switching account…','info');
  const r=await fetch('/api/accounts/switch',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});
  const d=await r.json();
  if(d.success){toast(`Switched — connected as ${d.tag||'unknown'}!`,'ok');loadAccounts();pollStatus()}
  else toast(d.error||'Switch failed','err')
}

async function removeAccount(id){
  await fetch(`/api/accounts/${id}`,{method:'DELETE'});loadAccounts()
}

// ── Backup / Restore ───────────────────────────────────────────────────────────
function downloadBackup(){window.location.href='/api/backup';toast('Downloading backup…','info')}

async function handleRestoreFile(input){
  const file=input.files[0];if(!file)return;
  try{
    const text=await file.text();const data=JSON.parse(text);
    const r=await fetch('/api/restore',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    const d=await r.json();
    if(d.success){toast(`Restored: ${d.restored.join(', ')}`,'ok');await Promise.all([loadConfig(),loadSettingsData()])}
    else toast(d.error||'Restore failed','err');
  }catch(err){toast('Invalid backup file: '+err.message,'err')}
  input.value='';
}

// ── Quests ────────────────────────────────────────────────────────────────────
async function fetchQuests(){
  const c=document.getElementById('questList');c.innerHTML='<div style="color:var(--text-2);font-size:13px;padding:14px 0">Loading…</div>';
  try{const r=await fetch('/api/quests');const d=await r.json();if(!d.success){c.innerHTML=`<div style="color:var(--red);font-size:13px">${e(d.error)}</div>`;return}
    const quests=d.quests||[];if(!quests.length){c.innerHTML='<div style="color:var(--text-2);font-size:13px;text-align:center;padding:22px 0">No quests available</div>';return}
    c.innerHTML='<div class="quest-grid">'+quests.map(q=>{
      const tag=q.completed?'<span class="badge badge-green">Done</span>':q.expired?'<span class="badge badge-red">Expired</span>':q.type==='PLAY_ON_DESKTOP'?'<span class="badge badge-cyan">Play</span>':'<span class="badge badge-purple">Video</span>';
      const btn=(!q.completed&&!q.expired)?`<button class="btn btn-ghost" style="padding:4px 10px;font-size:12px" onclick="startOneQuest('${q.id}')">Start</button>`:'';
      return`<div class="quest-card"><div class="quest-game">${e(q.game||q.name)}</div><div class="quest-name">${e(q.name)}</div><div class="quest-foot">${tag}${btn}</div></div>`;
    }).join('')+'</div>';
  }catch(err){c.innerHTML=`<div style="color:var(--red);font-size:13px">${e(err.message)}</div>`}
}

async function startQuests(){const r=await fetch('/api/quests/start',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'});const d=await r.json();if(!d.success){toast(d.error||'Failed','err');return}toast('Quests started','ok');startQuestPoll()}
async function startOneQuest(id){const r=await fetch('/api/quests/start',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({questId:id})});const d=await r.json();if(!d.success){toast(d.error||'Failed','err');return}toast('Quest started','ok');startQuestPoll()}
async function stopQuests(){await fetch('/api/quests/stop',{method:'POST'});toast('Stopped','info');stopQuestPoll()}
function startQuestPoll(){if(!questPollTimer){questPollTimer=setInterval(pollQuestStatus,1500);pollQuestStatus()}}
function stopQuestPoll(){clearInterval(questPollTimer);questPollTimer=null;document.getElementById('questBanner').style.display='none';document.getElementById('stopQuestBtn').style.display='none'}
async function pollQuestStatus(){
  try{const r=await fetch('/api/quests/status');const d=await r.json();
    const banner=document.getElementById('questBanner');
    if(d.isRunning){banner.style.display='flex';document.getElementById('questBannerText').textContent=d.currentQuest?`Running: ${d.currentQuest.name}`:'Running quests…';document.getElementById('stopQuestBtn').style.display=''}
    else{banner.style.display='none';document.getElementById('stopQuestBtn').style.display='none';if(questPollTimer){stopQuestPoll();loadQuestHistory()}}
    renderLogs(d.logs||[]);
  }catch{}
}
function renderLogs(logs){const el=document.getElementById('logTerminal');el.innerHTML=logs.map(l=>{const cls=l.includes('COMPLETED')?'log-ok':l.includes('Error')||l.includes('error')?'log-err':l.includes('Progress')||l.includes('Heartbeat')?'log-dim':'log-info';return`<div class="${cls}">${e(l)}</div>`}).join('');el.scrollTop=el.scrollHeight}
async function clearLogs(){await fetch('/api/quests/clear-logs',{method:'POST'});document.getElementById('logTerminal').innerHTML=''}
async function loadQuestHistory(){
  try{const r=await fetch('/api/quests/history');const d=await r.json();const history=d.history||[];
    const el=document.getElementById('setQuestsTotal');if(el)el.textContent=history.filter(h=>h.success).length;
    const tbody=document.getElementById('historyBody');if(!tbody)return;
    if(!history.length){tbody.innerHTML='<tr><td colspan="3" class="dim" style="text-align:center;padding:18px">No history yet</td></tr>';return}
    tbody.innerHTML=history.slice(0,50).map(h=>{const dt=new Date(h.completedAt);return`<tr><td>${e(h.name)}</td><td>${h.success?'<span class="badge badge-green">Done</span>':'<span class="badge badge-red">Failed</span>'}</td><td class="dim">${dt.toLocaleDateString()} ${dt.toLocaleTimeString()}</td></tr>`}).join('')
  }catch{}
}
async function clearHistory(){await fetch('/api/quests/history',{method:'DELETE'});document.getElementById('historyBody').innerHTML='<tr><td colspan="3" class="dim" style="text-align:center;padding:18px">No history yet</td></tr>';toast('History cleared','info')}

// ── Auto Features ─────────────────────────────────────────────────────────────
async function loadAutoFeatures(){
  try{const r=await fetch('/api/auto');const d=await r.json();autoFeaturesCfg=d.config||{};
    st('afkToggle',!!autoFeaturesCfg.afk?.enabled);sv('afkMsg',autoFeaturesCfg.afk?.message||'');sv('afkCooldown',Math.round((autoFeaturesCfg.afk?.cooldownMs||300000)/60000));
    st('reactToggle',!!autoFeaturesCfg.autoReact?.enabled);renderReactList(autoFeaturesCfg.autoReact?.textTriggers||{});
    st('replyToggle',!!autoFeaturesCfg.autoReply?.enabled);sv('replyCooldown',Math.round((autoFeaturesCfg.autoReply?.cooldownMs||0)/60000));renderReplyList(autoFeaturesCfg.autoReply?.rules||[]);
    st('kwToggle',!!(autoFeaturesCfg.keywordAlerts?.enabled||settings.keywordAlerts?.enabled));renderKwList(settings.keywordAlerts?.keywords||autoFeaturesCfg.keywordAlerts?.keywords||[]);
  }catch{}
}
async function saveAutoFeatures(){
  const payload={afk:{enabled:on('afkToggle'),message:gv('afkMsg'),cooldownMs:(parseInt(gv('afkCooldown'))||5)*60000},autoReact:{enabled:on('reactToggle'),userTriggers:autoFeaturesCfg.autoReact?.userTriggers||{},textTriggers:autoFeaturesCfg.autoReact?.textTriggers||{}},autoReply:{enabled:on('replyToggle'),cooldownMs:(parseInt(gv('replyCooldown'))||0)*60000,rules:autoFeaturesCfg.autoReply?.rules||[]},keywordAlerts:{enabled:on('kwToggle'),keywords:settings.keywordAlerts?.keywords||[]}};
  try{const r=await fetch('/api/auto',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const d=await r.json();if(d.success){autoFeaturesCfg=d.config;toast('Saved','ok')}else toast(d.error||'Failed','err')}catch{toast('Failed','err')}
  const us={...settings,keywordAlerts:{enabled:on('kwToggle'),keywords:settings.keywordAlerts?.keywords||[]}};
  fetch('/api/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(us)}).catch(()=>{});
}
function addReactTrigger(){const kw=gv('reactKw').trim(),emoji=gv('reactEmoji').trim();if(!kw||!emoji){toast('Enter keyword and emoji','err');return}if(!autoFeaturesCfg.autoReact)autoFeaturesCfg.autoReact={enabled:false,userTriggers:{},textTriggers:{}};if(!autoFeaturesCfg.autoReact.textTriggers)autoFeaturesCfg.autoReact.textTriggers={};autoFeaturesCfg.autoReact.textTriggers[kw]=[emoji];renderReactList(autoFeaturesCfg.autoReact.textTriggers);sv('reactKw','');sv('reactEmoji','')}
function removeReactTrigger(kw){delete autoFeaturesCfg.autoReact.textTriggers[kw];renderReactList(autoFeaturesCfg.autoReact.textTriggers)}
function renderReactList(triggers){document.getElementById('reactList').innerHTML=Object.entries(triggers||{}).map(([kw,em])=>`<div class="item-row"><span class="im">${e(em.join(' '))}</span><span class="it">${e(kw)}</span><button class="icon-btn del" onclick="removeReactTrigger('${e(kw)}')"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:7px">No triggers</div>'}
function addReplyRule(){const match=gv('replyMatch').trim(),reply=gv('replyText').trim();if(!match||!reply){toast('Enter match and reply','err');return}if(!autoFeaturesCfg.autoReply)autoFeaturesCfg.autoReply={enabled:false,rules:[]};autoFeaturesCfg.autoReply.rules.push({match,reply,exact:false});renderReplyList(autoFeaturesCfg.autoReply.rules);sv('replyMatch','');sv('replyText','')}
function removeReplyRule(i){autoFeaturesCfg.autoReply.rules.splice(i,1);renderReplyList(autoFeaturesCfg.autoReply.rules)}
function renderReplyList(rules){document.getElementById('replyList').innerHTML=(rules||[]).map((r,i)=>`<div class="item-row"><span class="im">${e(r.match)}</span><span class="it">→ ${e(r.reply)}</span><button class="icon-btn del" onclick="removeReplyRule(${i})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:7px">No rules</div>'}

// ── Messages ──────────────────────────────────────────────────────────────────
async function loadMessages(){try{const r=await fetch('/api/messages');const d=await r.json();renderScheduled(d.scheduled||[]);renderRecurring(d.recurring||[])}catch{}}
async function addScheduled(){const payload={targetId:gv('schTarget'),message:gv('schMsg'),runAt:new Date(gv('schTime')).getTime()};if(!payload.targetId||!payload.message||!payload.runAt){toast('Fill all fields','err');return}const r=await fetch('/api/messages/scheduled',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const d=await r.json();if(d.success){toast('Scheduled!','ok');loadMessages();sv('schTarget','');sv('schMsg','')}else toast(d.error||'Failed','err')}
async function addRecurring(){const payload={targetId:gv('recTarget'),message:gv('recMsg'),interval:parseInt(gv('recInterval')),unit:gv('recUnit')};if(!payload.targetId||!payload.message||!payload.interval){toast('Fill all fields','err');return}const r=await fetch('/api/messages/recurring',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const d=await r.json();if(d.success){toast('Added!','ok');loadMessages();sv('recTarget','');sv('recMsg','')}else toast(d.error||'Failed','err')}
function renderScheduled(list){document.getElementById('scheduledList').innerHTML=list.map(m=>{const dt=new Date(m.runAt);return`<div class="item-row"><span class="it">${e(m.targetId)}</span><span class="im">${dt.toLocaleDateString()} ${dt.toLocaleTimeString()}</span><button class="icon-btn del" onclick="fetch('/api/messages/scheduled/${m.id}',{method:'DELETE'}).then(()=>loadMessages())"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`}).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:8px">None scheduled</div>'}
function renderRecurring(list){document.getElementById('recurringList').innerHTML=list.map(m=>`<div class="item-row"><span class="it">${e(m.targetId)}</span><span class="im">every ${m.interval} ${m.unit}</span><button class="icon-btn del" onclick="fetch('/api/messages/recurring/${m.id}',{method:'DELETE'}).then(()=>loadMessages())"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`).join('')||'<div style="color:var(--text-3);font-size:12px;text-align:center;padding:8px">None set</div>'}

// ── Utility ───────────────────────────────────────────────────────────────────
async function purgeMessages(){const ch=gv('purgeChannel');if(!ch){toast('Enter a channel ID','err');return}const r=await fetch('/api/util/purge',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({channelId:ch,count:parseInt(gv('purgeCount'))||10})});const d=await r.json();d.success?toast(`Deleted ${d.deleted} messages`,'ok'):toast(d.error||'Failed','err')}
async function sendMessage(){const targetId=gv('sendTarget'),message=gv('sendMsg');if(!targetId||!message){toast('Fill all fields','err');return}const r=await fetch('/api/util/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({targetId,message})});const d=await r.json();if(d.success){toast('Sent!','ok');sv('sendMsg','')}else toast(d.error||'Failed','err')}
async function massDm(){const ids=gv('massIds').split('\n').map(s=>s.trim()).filter(Boolean);const message=gv('massMsg');if(!ids.length||!message){toast('Fill all fields','err');return}const r=await fetch('/api/util/massdm',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ids,message,delayMs:parseInt(gv('massDelay'))||1500})});const d=await r.json();d.success?toast(`Sent: ${d.sent}, Failed: ${d.failed}`,'ok'):toast(d.error||'Failed','err')}

// ── Settings ──────────────────────────────────────────────────────────────────
async function changePassword(){const pw=gv('newPw'),confirm=gv('confirmPw');if(!pw){toast('Enter a password','err');return}if(pw!==confirm){toast("Passwords don't match",'err');return}const r=await fetch('/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({panel_pass:pw})});const d=await r.json();if(d.success){toast('Password updated — redirecting…','ok');setTimeout(()=>location.href='/login',2000)}else toast(d.error||'Failed','err')}

// ── Boot ──────────────────────────────────────────────────────────────────────
init();
</script>
</body>
