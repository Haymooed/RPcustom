<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Onyx</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117; --surface: #161b22; --card: #1c2130; --card-2: #21262d;
  --border: rgba(255,255,255,0.07); --border-focus: rgba(6,182,212,0.4);
  --primary: #06b6d4; --grad: linear-gradient(135deg,#06b6d4,#6366f1);
  --grad-text: linear-gradient(135deg,#22d3ee,#818cf8);
  --text: #e6edf3; --text-2: #8b949e; --text-3: #3d444d;
  --green: #3fb950; --yellow: #d29922; --red: #f85149; --purple: #818cf8;
  --sidebar-w: 220px; --radius: 8px; --radius-lg: 12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg);color:var(--text);font-size:13.5px;line-height:1.5;height:100vh;display:flex;overflow:hidden}

/* Sidebar */
.sidebar{width:var(--sidebar-w);min-width:var(--sidebar-w);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:14px 10px;overflow:hidden}
.brand{display:flex;align-items:center;gap:9px;padding:4px 8px 16px;border-bottom:1px solid var(--border);margin-bottom:8px}
.brand-icon{width:28px;height:28px;background:var(--grad);border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 12px rgba(6,182,212,.22)}
.brand-icon svg{width:14px;height:14px;fill:#fff}
.brand-name{font-size:15px;font-weight:700;background:var(--grad-text);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.02em}
.nav-scroll{flex:1;overflow-y:auto;overflow-x:hidden}
.nav-scroll::-webkit-scrollbar{width:0}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:var(--radius);color:var(--text-2);cursor:pointer;transition:background .12s,color .12s;font-size:13px;font-weight:500;user-select:none;border:1px solid transparent;margin-bottom:2px;white-space:nowrap}
.nav-item:hover{background:var(--card);color:var(--text)}
.nav-item.active{background:rgba(6,182,212,.1);color:#22d3ee;border-color:rgba(6,182,212,.18)}
.nav-item svg{width:14px;height:14px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:1.8}
.nav-sep{height:1px;background:var(--border);margin:6px 4px}
.nav-label{font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;padding:6px 9px 3px}
.sidebar-footer{padding:10px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);margin-top:8px}
.status-info{display:flex;align-items:center;gap:7px;margin-bottom:8px}
.dot{width:7px;height:7px;border-radius:50%;background:var(--text-3);flex-shrink:0;transition:background .3s,box-shadow .3s}
.dot.connected{background:var(--green);box-shadow:0 0 6px rgba(63,185,80,.5)}
.dot.connecting{background:var(--yellow);animation:blink 1s infinite}
.dot.error{background:var(--red)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}
.status-name{font-size:12px;font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.footer-btns{display:flex;gap:5px}
.btn-sm{flex:1;padding:5px 8px;border-radius:6px;border:1px solid var(--border);background:var(--card-2);color:var(--text-2);font-size:11.5px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .12s;text-align:center}
.btn-sm:hover{color:var(--text)}
.btn-sm.primary{background:var(--grad);color:#fff;border-color:transparent;box-shadow:0 2px 8px rgba(6,182,212,.2)}
.btn-sm.danger{background:rgba(248,81,73,.1);color:var(--red);border-color:rgba(248,81,73,.2)}
.btn-sm.signout{width:100%;margin-top:5px}

/* Main */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{height:48px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0}
.topbar-title{font-size:14px;font-weight:600;flex:1}
.content{flex:1;overflow-y:auto;padding:20px}
.content::-webkit-scrollbar{width:4px}
.content::-webkit-scrollbar-thumb{background:rgba(255,255,255,.07);border-radius:2px}
.section{display:none}
.section.active{display:block}

/* Cards */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;margin-bottom:12px}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-title{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-2);display:flex;align-items:center;gap:6px}
.card-title svg{width:12px;height:12px;stroke:var(--primary);fill:none;stroke-width:2}

/* Layout */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.cols{display:flex;gap:12px}
.cols>.card{flex:1;margin-bottom:0}

/* Forms */
.field{display:flex;flex-direction:column;gap:4px}
label{font-size:10.5px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.07em}
input,select,textarea{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:13px;padding:7px 10px;outline:none;transition:border-color .12s,box-shadow .12s;font-family:inherit;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--border-focus);box-shadow:0 0 0 3px rgba(6,182,212,.07)}
input::placeholder,textarea::placeholder{color:var(--text-3)}
select option{background:var(--card)}
textarea{resize:vertical;min-height:68px;line-height:1.5}
.input-row{display:flex;gap:7px;align-items:flex-end}
.input-row .field{flex:1}
.form-gap{display:flex;flex-direction:column;gap:10px}

/* Buttons */
.btn{padding:7px 14px;border-radius:var(--radius);border:none;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .12s;display:inline-flex;align-items:center;gap:5px;white-space:nowrap}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}
.btn-full{width:100%;justify-content:center}
.btn-primary{background:var(--grad);color:#fff;box-shadow:0 2px 8px rgba(6,182,212,.2)}
.btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 4px 14px rgba(6,182,212,.3)}
.btn-ghost{background:var(--card-2);color:var(--text-2);border:1px solid var(--border)}
.btn-ghost:hover:not(:disabled){color:var(--text);border-color:rgba(255,255,255,.12)}
.btn-danger{background:rgba(248,81,73,.1);color:var(--red);border:1px solid rgba(248,81,73,.2)}
.btn-danger:hover:not(:disabled){background:rgba(248,81,73,.18)}
.icon-btn{width:26px;height:26px;border:none;background:transparent;border-radius:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-2);transition:all .12s;flex-shrink:0}
.icon-btn:hover{background:rgba(255,255,255,.06);color:var(--text)}
.icon-btn.del:hover{background:rgba(248,81,73,.1);color:var(--red)}
.icon-btn svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2}

/* Toggle */
.toggle-row{display:flex;align-items:center;gap:10px;padding:5px 0}
.toggle-info{flex:1}
.toggle-label{font-size:13px;font-weight:500}
.toggle-desc{font-size:11.5px;color:var(--text-2);margin-top:1px}
.toggle{width:36px;height:20px;background:var(--surface);border:1px solid var(--border);border-radius:10px;cursor:pointer;position:relative;transition:all .18s;flex-shrink:0}
.toggle.on{background:var(--primary);border-color:var(--primary);box-shadow:0 0 7px rgba(6,182,212,.3)}
.toggle::after{content:'';position:absolute;width:14px;height:14px;background:rgba(255,255,255,.4);border-radius:50%;top:2px;left:2px;transition:all .18s}
.toggle.on::after{left:18px;background:#fff}

/* Badges */
.badge{display:inline-flex;align-items:center;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
.badge-cyan{background:rgba(6,182,212,.12);color:#22d3ee}
.badge-green{background:rgba(63,185,80,.12);color:#3fb950}
.badge-red{background:rgba(248,81,73,.12);color:#f85149}
.badge-yellow{background:rgba(210,153,34,.12);color:#d29922}
.badge-purple{background:rgba(129,140,248,.12);color:#818cf8}
.badge-gray{background:rgba(255,255,255,.06);color:var(--text-2)}

/* Stat cards */
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:14px 16px}
.stat-val{font-size:24px;font-weight:700;background:var(--grad-text);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:3px}
.stat-lbl{font-size:11.5px;color:var(--text-2)}

/* Quest cards */
.quest-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px}
.quest-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:13px;display:flex;flex-direction:column;gap:9px;transition:border-color .12s}
.quest-card:hover{border-color:rgba(6,182,212,.2)}
.quest-game{font-size:13px;font-weight:600}
.quest-name{font-size:12px;color:var(--text-2)}
.quest-foot{display:flex;align-items:center;justify-content:space-between;gap:8px}

/* Terminal */
.terminal{background:#010409;border:1px solid var(--border);border-radius:var(--radius-lg);padding:12px 14px;font-family:'JetBrains Mono',monospace;font-size:11px;height:220px;overflow-y:auto;color:#8b949e;line-height:1.8}
.terminal::-webkit-scrollbar{width:3px}
.terminal::-webkit-scrollbar-thumb{background:rgba(255,255,255,.05)}
.log-ok{color:#3fb950}.log-err{color:#f85149}.log-info{color:#58a6ff}.log-dim{color:#484f58}

/* RPC preview */
.rpc-preview{background:#1e2130;border:1px solid rgba(6,182,212,.12);border-radius:var(--radius-lg);padding:13px;min-height:90px}
.preview-type{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#22d3ee;margin-bottom:4px}
.preview-name{font-size:13.5px;font-weight:700;margin-bottom:2px}
.preview-detail{font-size:12px;color:var(--text-2)}

/* Item list */
.item-list{display:flex;flex-direction:column;gap:4px;margin-top:8px}
.item-row{display:flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:6px 9px;font-size:13px}
.item-row .it{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-row .im{font-size:11px;color:var(--text-2);white-space:nowrap}

/* Quest banner */
.quest-banner{background:rgba(6,182,212,.07);border:1px solid rgba(6,182,212,.18);border-radius:var(--radius-lg);padding:10px 13px;display:flex;align-items:center;gap:9px;margin-bottom:12px}
.quest-banner-dot{width:7px;height:7px;background:var(--primary);border-radius:50%;animation:blink 1.2s infinite;flex-shrink:0}

/* Table */
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:7px 11px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-2);border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:9px 11px;border-bottom:1px solid rgba(255,255,255,.03);color:var(--text)}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.015)}
td.dim{color:var(--text-2);font-size:12px}

/* Save bar */
#saveBar{position:fixed;bottom:18px;right:20px;background:var(--card);border:1px solid rgba(6,182,212,.3);border-radius:var(--radius-lg);padding:10px 13px;display:none;align-items:center;gap:10px;box-shadow:0 8px 28px rgba(0,0,0,.5);z-index:200;animation:fadeUp .2s ease}
#saveBar.visible{display:flex}
.save-msg{font-size:12px;color:var(--text-2)}

/* Toasts */
#toasts{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column-reverse;gap:7px;z-index:500;pointer-events:none}
.toast{padding:8px 14px;border-radius:var(--radius);font-size:12.5px;font-weight:500;animation:fadeUp .2s ease;border:1px solid;white-space:nowrap}
.toast.ok{background:rgba(63,185,80,.12);border-color:rgba(63,185,80,.3);color:#3fb950}
.toast.err{background:rgba(248,81,73,.12);border-color:rgba(248,81,73,.3);color:#f85149}
.toast.info{background:rgba(6,182,212,.12);border-color:rgba(6,182,212,.3);color:#22d3ee}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}

/* DM Inbox */
.dm-layout{display:flex;gap:12px;height:560px}
.dm-list{width:240px;flex-shrink:0;overflow-y:auto;display:flex;flex-direction:column;gap:3px}
.dm-list::-webkit-scrollbar{width:3px}
.dm-list::-webkit-scrollbar-thumb{background:rgba(255,255,255,.06)}
.dm-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--radius);cursor:pointer;transition:background .1s;border:1px solid transparent}
.dm-item:hover{background:rgba(255,255,255,.04)}
.dm-item.active{background:rgba(6,182,212,.08);border-color:rgba(6,182,212,.15)}
.dm-avatar{width:34px;height:34px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.dm-avatar img{width:100%;height:100%;object-fit:cover}
.dm-info{flex:1;overflow:hidden}
.dm-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.dm-preview{font-size:11.5px;color:var(--text-2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.dm-chat{flex:1;display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.dm-messages{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px}
.dm-messages::-webkit-scrollbar{width:3px}
.dm-messages::-webkit-scrollbar-thumb{background:rgba(255,255,255,.06)}
.dm-empty{display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-2);font-size:13px}
.msg-row{display:flex;gap:8px;align-items:flex-end}
.msg-row.self{flex-direction:row-reverse}
.msg-avatar{width:26px;height:26px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.msg-avatar img{width:100%;height:100%;object-fit:cover}
.msg-bubble{max-width:70%;padding:7px 11px;border-radius:10px;font-size:13px;line-height:1.5;word-break:break-word}
.msg-row.other .msg-bubble{background:var(--card-2);border-bottom-left-radius:3px}
.msg-row.self .msg-bubble{background:rgba(6,182,212,.15);border:1px solid rgba(6,182,212,.2);border-bottom-right-radius:3px}
.msg-time{font-size:10px;color:var(--text-3);margin-top:2px;text-align:center}
.dm-input-bar{padding:10px;border-top:1px solid var(--border);display:flex;gap:8px}
.dm-input-bar input{flex:1}

/* Server browser */
.server-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px}
.server-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:14px;display:flex;flex-direction:column;align-items:center;gap:9px;text-align:center;transition:border-color .12s}
.server-card:hover{border-color:rgba(6,182,212,.2)}
.server-icon{width:52px;height:52px;border-radius:14px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff;overflow:hidden;flex-shrink:0}
.server-icon img{width:100%;height:100%;object-fit:cover}
.server-name{font-size:13px;font-weight:600;word-break:break-word}
.server-meta{font-size:11.5px;color:var(--text-2)}

/* Account cards */
.account-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:13px;display:flex;align-items:center;gap:12px;transition:border-color .12s}
.account-card.active-acc{border-color:rgba(6,182,212,.3);background:rgba(6,182,212,.04)}
.acc-avatar{width:38px;height:38px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0}
.acc-info{flex:1;overflow:hidden}
.acc-name{font-size:13.5px;font-weight:600}
.acc-token{font-size:11px;color:var(--text-2);font-family:'JetBrains Mono',monospace;margin-top:1px}

/* Dashboard account card */
.dash-account{display:flex;align-items:center;gap:14px;padding:4px 0}
.dash-avatar{width:52px;height:52px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#fff;overflow:hidden;flex-shrink:0}
.dash-avatar img{width:100%;height:100%;object-fit:cover}
.dash-tag{font-size:18px;font-weight:700;background:var(--grad-text);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.dash-id{font-size:11.5px;color:var(--text-2);margin-top:2px;font-family:'JetBrains Mono',monospace}

@media(max-width:820px){.sidebar{width:48px;min-width:48px;padding:10px 5px}.brand-name,.nav-item span,.nav-label,.sidebar-footer .status-name,.footer-btns{display:none}.brand{justify-content:center;padding:4px}.nav-item{justify-content:center;padding:8px}.grid-2,.grid-3,.grid-4{grid-template-columns:1fr}.cols{flex-direction:column}.dm-layout{flex-direction:column;height:auto}.dm-list{width:100%;height:180px}}
</style>
</head>
<body>

<aside class="sidebar">
  <div class="brand">
    <div class="brand-icon"><svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5L12 1zm0 2.18l7 3.12V11c0 4.52-3.05 8.78-7 10.01C8.05 19.78 5 15.52 5 11V6.3l7-3.12z"/></svg></div>
    <span class="brand-name">Onyx</span>
  </div>
  <div class="nav-scroll">
    <div data-sec="dashboard" class="nav-item active" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span>Dashboard</span>
    </div>
    <div class="nav-sep"></div>
    <div data-sec="presence" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0112 0v2"/></svg>
      <span>Presence</span>
    </div>
    <div data-sec="quests" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      <span>Quests</span>
    </div>
    <div data-sec="automation" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <span>Automation</span>
    </div>
    <div data-sec="messages" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      <span>Messages</span>
    </div>
    <div data-sec="utility" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
      <span>Utility</span>
    </div>
    <div class="nav-sep"></div>
    <div data-sec="dms" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <span>DM Inbox</span>
    </div>
    <div data-sec="servers" class="nav-item" onclick="showSection(this)">
      <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
      <span>Servers</span>
    </div>
    <div data-sec="accounts" class="nav-item" onclick="showSection(this)">
