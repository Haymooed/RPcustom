      <div class="card-title" style="margin-bottom:12px"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>Add Account</div>
      <div class="form-gap">
