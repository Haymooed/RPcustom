    <div class="stat-card"><div class="stat-val" id="setStatus">—</div><div class="stat-lbl">Connection</div></div>
    <div class="stat-card"><div class="stat-val" id="setAccounts">—</div><div class="stat-lbl">Accounts</div></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title" style="margin-bottom:12px"><svg viewBox="0 0 24 24"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>Webhook Notifications</div>
