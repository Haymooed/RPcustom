      <div class="card-title" style="margin-bottom:12px"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>Mass DM</div>
      <div class="grid-2"><div class="field"><label>User IDs (one per line)</label><textarea id="massIds" placeholder="123456789&#10;987654321" style="min-height:90px"></textarea></div><div class="form-gap"><div class="field"><label>Message</label><textarea id="massMsg" placeholder="Your message"></textarea></div><div class="field"><label>Delay between DMs (ms)</label><input type="number" id="massDelay" value="1500" min="1000"></div><button class="btn btn-primary btn-full" onclick="massDm()">Send Mass DM</button></div></div>
    </div>
  </div>
</div>

