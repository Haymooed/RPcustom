      </div>
    </div>
    <div class="grid-2">
      <div class="toggle-row"><div class="toggle-info"><div class="toggle-label">Auto-Claim Rewards</div><div class="toggle-desc">Claim rewards automatically on completion</div></div><div class="toggle" id="autoClaimToggle" onclick="this.classList.toggle('on');saveSettings()"></div></div>
      <div class="toggle-row"><div class="toggle-info"><div class="toggle-label">Completion Notifications</div><div class="toggle-desc">Webhook ping when a quest finishes</div></div><div class="toggle" id="questNotifToggle" onclick="this.classList.toggle('on');saveSettings()"></div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-title" style="margin-bottom:12px"><svg viewBox="0 0 24 24"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>Available Quests</div>
    <div id="questList"><div style="color:var(--text-2);font-size:13px;text-align:center;padding:22px 0">Click Refresh to load quests</div></div>
  </div>
  <div class="card">
    <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Quest History</div><button class="btn btn-ghost" onclick="clearHistory()">Clear</button></div>
    <div class="table-wrap"><table><thead><tr><th>Quest</th><th>Status</th><th>Completed</th></tr></thead><tbody id="historyBody"><tr><td colspan="3" class="dim" style="text-align:center;padding:18px">No history yet</td></tr></tbody></table></div>
  </div>
  <div class="card">
    <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>Protocol Logs</div><button class="btn btn-ghost" onclick="clearLogs()">Clear</button></div>
    <div class="terminal" id="logTerminal"></div>
  </div>
</div>

