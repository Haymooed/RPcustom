<!-- ══════════════════════════════════════════════════════
     PRESENCE
════════════════════════════════════════════════════════ -->
<div id="sec-presence" class="section">
  <div class="card">
    <div class="card-header">
      <div class="card-title"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="var(--primary)" stroke="none"/></svg>Connection</div>
    </div>
    <div class="grid-2">
      <div class="form-gap">
        <div class="field">
          <label>Discord Token</label>
          <div class="input-row">
            <input type="password" id="tokenInput" placeholder="Your Discord token" oninput="markDirty()" style="flex:1">
            <button class="btn btn-ghost" onclick="validateToken()">Validate</button>
          </div>
        </div>
        <div class="field">
          <label>Status</label>
          <select id="statusSelect" onchange="markDirty()">
            <option value="online">🟢 Online</option><option value="idle">🟡 Idle</option>
            <option value="dnd">🔴 Do Not Disturb</option><option value="invisible">⚫ Invisible</option>
          </select>
        </div>
      </div>
      <div id="tokenValidResult" style="display:flex;align-items:center;justify-content:center;color:var(--text-2);font-size:13px;text-align:center">Click "Validate" to check your token</div>
    </div>
  </div>
  <div class="cols">
    <div class="card" style="flex:1.5">
      <div class="card-header">
        <div class="card-title"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>Rich Presence</div>
        <div class="toggle" id="rpcToggle" onclick="this.classList.toggle('on');markDirty()"></div>
      </div>
      <div class="form-gap">
        <div class="grid-2">
          <div class="field"><label>Activity Type</label><select id="actType" onchange="updatePreview();markDirty()"><option value="PLAYING">Playing</option><option value="STREAMING">Streaming</option><option value="LISTENING">Listening</option><option value="WATCHING">Watching</option><option value="COMPETING">Competing</option></select></div>
          <div class="field"><label>Application ID</label><input type="text" id="appId" placeholder="1234567890" oninput="updatePreview();markDirty()"></div>
        </div>
        <div class="field"><label>Name</label><input type="text" id="rpcName" placeholder="What are you doing?" oninput="updatePreview();markDirty()"></div>
        <div class="grid-2">
          <div class="field"><label>Details</label><input type="text" id="rpcDetails" placeholder="Details line" oninput="updatePreview();markDirty()"></div>
          <div class="field"><label>State</label><input type="text" id="rpcState" placeholder="State line" oninput="updatePreview();markDirty()"></div>
        </div>
        <div class="field" id="streamUrlField" style="display:none"><label>Stream URL</label><input type="text" id="streamUrl" placeholder="https://twitch.tv/..." oninput="markDirty()"></div>
        <div class="grid-2">
          <div class="field"><label>Large Image</label><input type="text" id="largeImg" placeholder="URL or asset" oninput="markDirty()"></div>
          <div class="field"><label>Large Text</label><input type="text" id="largeText" placeholder="Hover text" oninput="markDirty()"></div>
        </div>
        <div class="grid-2">
          <div class="field"><label>Small Image</label><input type="text" id="smallImg" placeholder="URL or asset" oninput="markDirty()"></div>
          <div class="field"><label>Small Text</label><input type="text" id="smallText" placeholder="Hover text" oninput="markDirty()"></div>
        </div>
        <div class="grid-2">
          <div class="field"><label>Button 1 Label</label><input type="text" id="btn1text" placeholder="Click here" oninput="markDirty()"></div>
          <div class="field"><label>Button 1 URL</label><input type="text" id="btn1url" placeholder="https://..." oninput="markDirty()"></div>
        </div>
        <div class="grid-2">
          <div class="field"><label>Button 2 Label</label><input type="text" id="btn2text" placeholder="Click here" oninput="markDirty()"></div>
          <div class="field"><label>Button 2 URL</label><input type="text" id="btn2url" placeholder="https://..." oninput="markDirty()"></div>
        </div>
        <div class="toggle-row"><div class="toggle-info"><div class="toggle-label">Show Elapsed Time</div></div><div class="toggle" id="elapsedToggle" onclick="this.classList.toggle('on');markDirty()"></div></div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;min-width:195px;flex:1">
      <div class="card" style="margin-bottom:0">
        <div class="card-title" style="margin-bottom:10px"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>Live Preview</div>
        <div class="rpc-preview"><div class="preview-type" id="prevType">PLAYING</div><div class="preview-name" id="prevName">Onyx</div><div class="preview-detail" id="prevDetails" style="display:none"></div><div class="preview-detail" id="prevState" style="display:none"></div></div>
      </div>
      <div class="card" style="margin-bottom:0">
        <div class="card-header">
          <div class="card-title"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>Custom Status</div>
          <div class="toggle" id="csToggle" onclick="this.classList.toggle('on');markDirty()"></div>
        </div>
        <div class="form-gap">
          <div class="field"><label>Status Text</label><input type="text" id="csText" placeholder="What's happening?" oninput="markDirty()"></div>
          <div class="field"><label>Emoji</label><input type="text" id="csEmoji" placeholder="😊 or :custom:" oninput="markDirty()"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <div class="card-title"><svg viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>Presence Rotation</div>
      <div class="toggle" id="rotToggle" onclick="this.classList.toggle('on')"></div>
    </div>
    <div class="form-gap">
      <div class="input-row" style="align-items:flex-end">
        <div class="field" style="max-width:150px"><label>Interval (min)</label><input type="number" id="rotInterval" value="5" min="1"></div>
        <button class="btn btn-ghost" onclick="saveSettings()">Apply</button>
      </div>
      <div class="input-row">
        <div class="field"><label>Type</label><select id="rotType"><option value="PLAYING">Playing</option><option value="LISTENING">Listening</option><option value="WATCHING">Watching</option><option value="COMPETING">Competing</option></select></div>
        <div class="field"><label>Name</label><input type="text" id="rotName" placeholder="e.g. Spotify"></div>
        <div class="field"><label>App ID (opt)</label><input type="text" id="rotAppId" placeholder="Optional"></div>
        <button class="btn btn-ghost" style="align-self:flex-end" onclick="addRotEntry()">Add</button>
      </div>
      <div class="item-list" id="rotList"></div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <div class="card-title"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Idle Spoofing</div>
      <div class="toggle" id="idleToggle" onclick="this.classList.toggle('on')"></div>
    </div>
    <div class="input-row" style="align-items:flex-end">
      <div class="field"><label>Go idle after (minutes of no activity)</label><input type="number" id="idleTimeout" value="10" min="1" max="120"></div>
      <button class="btn btn-ghost" onclick="saveSettings()">Apply</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     QUESTS
