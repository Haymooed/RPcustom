<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Onyx</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --card: #1c2130;
  --card-2: #21262d;
  --border: rgba(255,255,255,0.07);
  --border-focus: rgba(6,182,212,0.4);
  --primary: #06b6d4;
  --primary-2: #6366f1;
  --grad: linear-gradient(135deg, #06b6d4, #6366f1);
  --grad-text: linear-gradient(135deg, #22d3ee, #818cf8);
  --text: #e6edf3;
  --text-2: #8b949e;
  --text-3: #3d444d;
  --green: #3fb950;
  --yellow: #d29922;
  --red: #f85149;
  --sidebar-w: 224px;
  --radius: 8px;
  --radius-lg: 12px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: 13.5px;
  line-height: 1.5;
  height: 100vh;
  display: flex;
  overflow: hidden;
}

/* ── Sidebar ── */
.sidebar {
  width: var(--sidebar-w);
  min-width: var(--sidebar-w);
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 16px 10px;
  overflow: hidden;
}

.brand {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 6px 10px 18px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 10px;
}

.brand-icon {
  width: 30px;
  height: 30px;
  background: var(--grad);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 14px rgba(6,182,212,0.25);
}

.brand-icon svg { width: 16px; height: 16px; fill: #fff; }

.brand-name {
  font-size: 15px;
  font-weight: 700;
  background: var(--grad-text);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.02em;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 8px 10px;
  border-radius: var(--radius);
  color: var(--text-2);
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
  font-size: 13px;
  font-weight: 500;
  user-select: none;
  border: 1px solid transparent;
  margin-bottom: 2px;
}

.nav-item:hover { background: var(--card); color: var(--text); }
.nav-item.active { background: rgba(6,182,212,0.1); color: #22d3ee; border-color: rgba(6,182,212,0.18); }
.nav-item svg { width: 15px; height: 15px; flex-shrink: 0; stroke: currentColor; fill: none; stroke-width: 1.8; }

.nav-sep { height: 1px; background: var(--border); margin: 8px 4px; }

.sidebar-footer {
  margin-top: auto;
  padding: 12px 10px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}

.status-info { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }

.dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--text-3);
  flex-shrink: 0;
  transition: background 0.3s, box-shadow 0.3s;
}
.dot.connected { background: var(--green); box-shadow: 0 0 6px rgba(63,185,80,0.5); }
.dot.connecting { background: var(--yellow); animation: blink 1s infinite; }
.dot.error { background: var(--red); }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.35} }

.status-name { font-size: 12.5px; font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.footer-btns { display: flex; gap: 6px; }

.btn-sm {
  flex: 1;
  padding: 6px 10px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: var(--card-2);
  color: var(--text-2);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.12s;
  text-align: center;
}

.btn-sm:hover { color: var(--text); border-color: rgba(255,255,255,0.12); }
.btn-sm.primary { background: var(--grad); color: #fff; border-color: transparent; box-shadow: 0 2px 10px rgba(6,182,212,0.2); }
.btn-sm.primary:hover { box-shadow: 0 2px 14px rgba(6,182,212,0.35); }
.btn-sm.danger { background: rgba(248,81,73,0.1); color: var(--red); border-color: rgba(248,81,73,0.2); }
.btn-sm.danger:hover { background: rgba(248,81,73,0.18); }

/* ── Main ── */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

.topbar {
  height: 50px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22px;
  flex-shrink: 0;
}

.topbar-title { font-size: 14px; font-weight: 600; }

.content {
  flex: 1;
  overflow-y: auto;
  padding: 22px;
}

.content::-webkit-scrollbar { width: 4px; }
.content::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); border-radius: 2px; }

/* ── Sections ── */
.section { display: none; }
.section.active { display: block; }

/* ── Cards ── */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 18px;
  margin-bottom: 14px;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.card-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-2);
  display: flex;
  align-items: center;
  gap: 7px;
}

.card-title svg { width: 13px; height: 13px; stroke: var(--primary); fill: none; stroke-width: 2; }

/* ── Layout ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
.cols { display: flex; gap: 14px; }
.cols > .card { flex: 1; margin-bottom: 0; }

/* ── Form elements ── */
.field { display: flex; flex-direction: column; gap: 5px; }

label {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

input, select, textarea {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-size: 13px;
  padding: 8px 11px;
  outline: none;
  transition: border-color 0.12s, box-shadow 0.12s;
  font-family: inherit;
  width: 100%;
}

input:focus, select:focus, textarea:focus {
  border-color: var(--border-focus);
  box-shadow: 0 0 0 3px rgba(6,182,212,0.07);
}

input::placeholder, textarea::placeholder { color: var(--text-3); }
select option { background: var(--card); }
textarea { resize: vertical; min-height: 72px; line-height: 1.5; }

.input-row { display: flex; gap: 8px; align-items: flex-end; }
.input-row .field { flex: 1; }
.form-gap { display: flex; flex-direction: column; gap: 12px; }

/* ── Buttons ── */
.btn {
  padding: 8px 16px;
  border-radius: var(--radius);
  border: none;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.12s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }
.btn-full { width: 100%; justify-content: center; }

.btn-primary { background: var(--grad); color: #fff; box-shadow: 0 2px 10px rgba(6,182,212,0.2); }
.btn-primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(6,182,212,0.3); }

.btn-ghost { background: var(--card-2); color: var(--text-2); border: 1px solid var(--border); }
.btn-ghost:hover:not(:disabled) { color: var(--text); border-color: rgba(255,255,255,0.12); }

.btn-danger { background: rgba(248,81,73,0.1); color: var(--red); border: 1px solid rgba(248,81,73,0.2); }
.btn-danger:hover:not(:disabled) { background: rgba(248,81,73,0.18); }

.icon-btn {
  width: 28px; height: 28px;
  border: none; background: transparent;
  border-radius: 6px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-2); transition: all 0.12s; flex-shrink: 0;
}

.icon-btn:hover { background: rgba(255,255,255,0.06); color: var(--text); }
.icon-btn.del:hover { background: rgba(248,81,73,0.1); color: var(--red); }
.icon-btn svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; }

/* ── Toggle ── */
.toggle-row { display: flex; align-items: center; gap: 12px; padding: 6px 0; }
.toggle-info { flex: 1; }
.toggle-label { font-size: 13.5px; font-weight: 500; color: var(--text); }
.toggle-desc { font-size: 12px; color: var(--text-2); margin-top: 1px; }

.toggle {
  width: 38px; height: 21px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 11px; cursor: pointer;
  position: relative; transition: all 0.18s; flex-shrink: 0;
}

.toggle.on { background: var(--primary); border-color: var(--primary); box-shadow: 0 0 8px rgba(6,182,212,0.3); }
.toggle::after {
  content: ''; position: absolute;
  width: 15px; height: 15px;
  background: rgba(255,255,255,0.45); border-radius: 50%;
  top: 2px; left: 2px; transition: all 0.18s;
}
.toggle.on::after { left: 19px; background: #fff; }

/* ── Badge ── */
.badge {
  display: inline-flex; align-items: center;
  padding: 2px 7px; border-radius: 4px;
  font-size: 10.5px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.04em;
}

.badge-cyan   { background: rgba(6,182,212,0.12);  color: #22d3ee; }
.badge-green  { background: rgba(63,185,80,0.12);  color: #3fb950; }
.badge-red    { background: rgba(248,81,73,0.12);  color: #f85149; }
.badge-yellow { background: rgba(210,153,34,0.12); color: #d29922; }
.badge-purple { background: rgba(99,102,241,0.12); color: #818cf8; }
.badge-gray   { background: rgba(255,255,255,0.06);color: var(--text-2); }

/* ── Quest cards ── */
.quest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(256px, 1fr)); gap: 10px; }

.quest-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 14px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color 0.12s;
}
.quest-card:hover { border-color: rgba(6,182,212,0.2); }
.quest-game { font-size: 13.5px; font-weight: 600; }
.quest-name { font-size: 12px; color: var(--text-2); }
.quest-foot { display: flex; align-items: center; gap: 8px; justify-content: space-between; }

/* ── Terminal ── */
.terminal {
  background: #010409; border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 14px 16px;
  font-family: 'JetBrains Mono', monospace; font-size: 11.5px;
  height: 240px; overflow-y: auto; color: #8b949e; line-height: 1.8;
}
.terminal::-webkit-scrollbar { width: 4px; }
.terminal::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.06); }
.log-ok   { color: #3fb950; }
.log-err  { color: #f85149; }
.log-info { color: #58a6ff; }
.log-dim  { color: #484f58; }

/* ── Preview ── */
.rpc-preview {
  background: #1e2130; border: 1px solid rgba(6,182,212,0.12);
  border-radius: var(--radius-lg); padding: 14px; min-height: 100px;
}
.preview-type { font-size: 10.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #22d3ee; margin-bottom: 5px; }
.preview-name { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
.preview-detail { font-size: 12.5px; color: var(--text-2); }

/* ── Item list ── */
.item-list { display: flex; flex-direction: column; gap: 5px; margin-top: 10px; }

.item-row {
  display: flex; align-items: center; gap: 8px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 7px 10px; font-size: 13px;
}
.item-row .it { flex: 1; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-row .im { font-size: 11px; color: var(--text-2); white-space: nowrap; }

/* ── Quest banner ── */
.quest-banner {
  background: rgba(6,182,212,0.07); border: 1px solid rgba(6,182,212,0.18);
  border-radius: var(--radius-lg); padding: 11px 14px;
  display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
}
.quest-banner-dot {
  width: 7px; height: 7px; background: var(--primary);
  border-radius: 50%; animation: blink 1.2s infinite;
}

/* ── Table ── */
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th {
  text-align: left; padding: 8px 12px; font-size: 10.5px;
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
  color: var(--text-2); border-bottom: 1px solid var(--border); white-space: nowrap;
}
td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text); }
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,0.018); }
td.dim { color: var(--text-2); font-size: 12px; }

/* ── Stats ── */
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
.stat-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 14px 16px; }
.stat-val {
  font-size: 26px; font-weight: 700;
  background: var(--grad-text); -webkit-background-clip: text;
  background-clip: text; -webkit-text-fill-color: transparent;
  line-height: 1; margin-bottom: 4px;
}
.stat-lbl { font-size: 12px; color: var(--text-2); }

/* ── Save bar ── */
#saveBar {
  position: fixed; bottom: 20px; right: 22px;
  background: var(--card); border: 1px solid rgba(6,182,212,0.3);
  border-radius: var(--radius-lg); padding: 11px 14px;
  display: none; align-items: center; gap: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5); z-index: 200;
  animation: fadeUp 0.2s ease;
}
#saveBar.visible { display: flex; }
.save-msg { font-size: 12.5px; color: var(--text-2); }

/* ── Toasts ── */
#toasts {
  position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column-reverse; gap: 8px;
  z-index: 500; pointer-events: none;
}
.toast {
  padding: 9px 16px; border-radius: var(--radius);
  font-size: 13px; font-weight: 500;
  animation: fadeUp 0.2s ease; border: 1px solid; white-space: nowrap;
}
.toast.ok   { background: rgba(63,185,80,0.12);  border-color: rgba(63,185,80,0.3);  color: #3fb950; }
.toast.err  { background: rgba(248,81,73,0.12);  border-color: rgba(248,81,73,0.3);  color: #f85149; }
.toast.info { background: rgba(6,182,212,0.12);  border-color: rgba(6,182,212,0.3);  color: #22d3ee; }

@keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

/* ── Responsive ── */
@media (max-width: 820px) {
  .sidebar { width: 52px; min-width: 52px; padding: 12px 6px; }
  .brand-name, .nav-item span, .sidebar-footer .status-name, .footer-btns { display: none; }
  .brand { justify-content: center; padding: 6px; }
  .nav-item { justify-content: center; padding: 9px; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .grid-2 { grid-template-columns: 1fr; }
  .cols { flex-direction: column; }
}
</style>
</head>
<body>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <div class="brand">
    <div class="brand-icon">
      <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5L12 1zm0 2.18l7 3.12V11c0 4.52-3.05 8.78-7 10.01C8.05 19.78 5 15.52 5 11V6.3l7-3.12z"/></svg>
    </div>
    <span class="brand-name">Onyx</span>
  </div>

  <div data-sec="presence" class="nav-item active" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0112 0v2"/></svg>
    <span>Presence</span>
  </div>
  <div data-sec="quests" class="nav-item" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
    <span>Quests</span>
  </div>
  <div data-sec="automation" class="nav-item" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    <span>Automation</span>
  </div>
  <div data-sec="messages" class="nav-item" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    <span>Messages</span>
  </div>
  <div data-sec="utility" class="nav-item" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
    <span>Utility</span>
  </div>
  <div class="nav-sep"></div>
  <div data-sec="settings" class="nav-item" onclick="showSection(this)">
    <svg viewBox="0 0 24 24"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    <span>Settings</span>
  </div>

  <div class="sidebar-footer">
    <div class="status-info">
      <div class="dot" id="footDot"></div>
      <span class="status-name" id="footTag">Not connected</span>
    </div>
    <div class="footer-btns">
      <button class="btn-sm primary" id="connectBtn" onclick="toggleConnect()">Connect</button>
      <button class="btn-sm danger" id="disconnectBtn" style="display:none" onclick="toggleConnect()">Disconnect</button>
    </div>
    <button class="btn-sm" onclick="location.href='/login'" style="width:100%;margin-top:6px">Sign Out</button>
  </div>
</aside>

<!-- ── MAIN ── -->
<div class="main">
  <div class="topbar">
    <span class="topbar-title" id="topbarTitle">Presence</span>
  </div>

  <div class="content">

    <!-- ════════════ PRESENCE ════════════ -->
    <div id="sec-presence" class="section active">

      <!-- Connection -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="var(--primary)" stroke="none"/></svg>
            Connection
          </div>
        </div>
        <div class="grid-2">
          <div class="form-gap">
            <div class="field">
              <label>Discord Token</label>
              <div class="input-row">
                <input type="password" id="tokenInput" placeholder="Your Discord token" oninput="markDirty()" style="flex:1">
                <button class="btn btn-ghost" onclick="validateToken()">Validate</button>
              </div>
            </div>
            <div class="field">
              <label>Status</label>
              <select id="statusSelect" onchange="markDirty()">
                <option value="online">🟢 Online</option>
                <option value="idle">🟡 Idle</option>
                <option value="dnd">🔴 Do Not Disturb</option>
                <option value="invisible">⚫ Invisible</option>
              </select>
            </div>
          </div>
