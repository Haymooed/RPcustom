    <div class="card">
      <div class="card-title" style="margin-bottom:12px"><svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>Quick Send</div>
      <div class="form-gap"><div class="field"><label>Target ID</label><input type="text" id="sendTarget" placeholder="Channel or User ID"></div><div class="field"><label>Message</label><textarea id="sendMsg" placeholder="Your message"></textarea></div><button class="btn btn-primary btn-full" onclick="sendMessage()">Send</button></div>
    </div>
