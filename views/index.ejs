     AUTOMATION
════════════════════════════════════════════════════════ -->
<div id="sec-automation" class="section">
  <div class="grid-2">
    <div class="card">
      <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>AFK Responder</div><div class="toggle" id="afkToggle" onclick="this.classList.toggle('on')"></div></div>
      <div class="form-gap">
        <div class="field"><label>AFK Message</label><textarea id="afkMsg" placeholder="I'm AFK right now…"></textarea></div>
        <div class="field"><label>Per-user cooldown (minutes)</label><input type="number" id="afkCooldown" value="5" min="0"></div>
        <button class="btn btn-primary btn-full" onclick="saveAutoFeatures()">Save</button>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>Keyword Alerts</div><div class="toggle" id="kwToggle" onclick="this.classList.toggle('on')"></div></div>
      <div style="font-size:12px;color:var(--text-2);margin-bottom:8px">Webhook ping when these words appear in any message</div>
      <div class="input-row" style="margin-bottom:0"><input type="text" id="kwInput" placeholder="Keyword" style="flex:1" onkeydown="if(event.key==='Enter')addKeyword()"><button class="btn btn-ghost" onclick="addKeyword()">Add</button></div>
      <div class="item-list" id="kwList"></div>
      <button class="btn btn-primary btn-full" style="margin-top:10px" onclick="saveAutoFeatures()">Save</button>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>Auto React</div><div class="toggle" id="reactToggle" onclick="this.classList.toggle('on')"></div></div>
      <div style="font-size:12px;color:var(--text-2);margin-bottom:8px">React with an emoji when a keyword is mentioned</div>
      <div class="input-row" style="margin-bottom:0"><input type="text" id="reactKw" placeholder="Keyword" style="flex:1.5"><input type="text" id="reactEmoji" placeholder="😊" style="flex:.8"><button class="btn btn-ghost" onclick="addReactTrigger()">Add</button></div>
      <div class="item-list" id="reactList"></div>
      <button class="btn btn-primary btn-full" style="margin-top:10px" onclick="saveAutoFeatures()">Save</button>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title"><svg viewBox="0 0 24 24"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 00-4-4H4"/></svg>Auto Reply</div><div class="toggle" id="replyToggle" onclick="this.classList.toggle('on')"></div></div>
      <div class="field" style="margin-bottom:8px"><label>Per-user cooldown (min, 0=off)</label><input type="number" id="replyCooldown" value="0" min="0"></div>
      <div class="input-row" style="margin-bottom:0"><input type="text" id="replyMatch" placeholder="Match phrase" style="flex:1"><input type="text" id="replyText" placeholder="Reply with" style="flex:1"><button class="btn btn-ghost" onclick="addReplyRule()">Add</button></div>
      <div class="item-list" id="replyList"></div>
      <button class="btn btn-primary btn-full" style="margin-top:10px" onclick="saveAutoFeatures()">Save</button>
    </div>
  </div>
